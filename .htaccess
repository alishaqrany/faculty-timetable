# ─── Timetable Management System v2 ──────────────────────────
# Serves the application from the project root while keeping /public internal.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Allow requests that already target the public directory to continue there
    RewriteRule ^public(?:/.*)?$ - [L]

    # Expose assets and installer from public/ without forcing /public in URLs
    RewriteRule ^(assets/.*|install\.php)$ public/$1 [L,QSA]

    # Pass through real files and directories in the project root
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route application requests directly through public/index.php
    RewriteRule ^$ public/index.php [L,QSA]
    RewriteRule ^(.+)$ public/index.php [L,QSA]
</IfModule>

# ─── Security: Deny access to sensitive directories ─────────
<IfModule mod_rewrite.c>
    RewriteRule ^(app|core|config|database|storage|_legacy)/ - [F,L]
</IfModule>

# Fallback: deny direct access via FilesMatch
<FilesMatch "\.(env|lock|md|json|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
